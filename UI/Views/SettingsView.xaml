<UserControl x:Class="KighmuVpnWindows.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundDarkBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Réglages" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" />

            <!-- ===== Hardware ID ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="IDENTIFIANT APPAREIL" Style="{StaticResource KighmuSectionHeader}" />
                    <TextBlock x:Name="TvHardwareId" Text="..." Foreground="{StaticResource AccentBlueBrush}"
                               FontFamily="Consolas" FontSize="12" Margin="0,4,0,8" TextWrapping="Wrap" />
                    <Button x:Name="BtnCopyHwid" Content="Copier Hardware ID"
                            Style="{StaticResource KighmuButton}" HorizontalAlignment="Left"
                            Click="BtnCopyHwid_Click" />
                </StackPanel>
            </Border>

            <!-- ===== General Windows ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="GÉNÉRAL" Style="{StaticResource KighmuSectionHeader}" />
                    <CheckBox x:Name="AutoStartCheck" Content="Démarrer avec Windows"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,4" />
                    <CheckBox x:Name="MinimizeToTrayCheck" Content="Réduire dans la barre des tâches"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                </StackPanel>
            </Border>

            <!-- ===== Connexion ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="CONNEXION" Style="{StaticResource KighmuSectionHeader}" />
                    <CheckBox x:Name="AutoReconnectCheck" Content="Reconnexion automatique"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,4" />
                    <CheckBox x:Name="KillSwitchCheck" Content="Kill Switch (couper internet si VPN déconnecté)"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="NotificationsCheck" Content="Notifications"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="WakelockCheck" Content="Wakelock (empêcher mise en veille)"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="KeepAliveCheck" Content="Keep Alive"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="CompressionCheck" Content="Compression des données"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="HttpPingCheck" Content="HTTP Ping"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                </StackPanel>
            </Border>

            <!-- ===== DNS ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="DNS" Style="{StaticResource KighmuSectionHeader}" />
                    <CheckBox x:Name="DnsProtectionCheck" Content="Protection DNS"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,4" />
                    <CheckBox x:Name="EnableDnsCheck" Content="Activer DNS personnalisé"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,4" />
                    <CheckBox x:Name="DnsForwardingCheck" Content="DNS Forwarding"
                              Foreground="{StaticResource TextPrimaryBrush}" Margin="0,4,0,8" />
                    <TextBlock Text="DNS Primaire" Style="{StaticResource KighmuSecondaryText}" Margin="0,4,0,2" />
                    <TextBox x:Name="DnsPrimaryBox" Text="8.8.8.8"
                             Style="{StaticResource KighmuTextBox}" Margin="0,0,0,8" />
                    <TextBlock Text="DNS Secondaire" Style="{StaticResource KighmuSecondaryText}" Margin="0,4,0,2" />
                    <TextBox x:Name="DnsSecondaryBox" Text="8.8.4.4"
                             Style="{StaticResource KighmuTextBox}" Margin="0,0,0,8" />
                </StackPanel>
            </Border>

            <!-- ===== Avance ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="AVANCÉ" Style="{StaticResource KighmuSectionHeader}" />
                    <TextBlock Text="MTU" Style="{StaticResource KighmuSecondaryText}" Margin="0,4,0,2" />
                    <TextBox x:Name="MtuBox" Text=""
                             Style="{StaticResource KighmuTextBox}" Margin="0,0,0,8" />
                    <TextBlock Text="UDPGW" Style="{StaticResource KighmuSecondaryText}" Margin="0,4,0,2" />
                    <TextBox x:Name="UdpgwBox" Text=""
                             Style="{StaticResource KighmuTextBox}" Margin="0,0,0,8" />
                </StackPanel>
            </Border>

            <!-- ===== A propos ===== -->
            <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="À PROPOS" Style="{StaticResource KighmuSectionHeader}" />
                    <TextBlock x:Name="TvAppVersion" Text="KIGHMU VPN v1.0.0"
                               Style="{StaticResource KighmuSecondaryText}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Button Content="Enregistrer les réglages" Style="{StaticResource KighmuButton}"
                    Margin="0,8,0,20" Click="SaveSettings_Click" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
