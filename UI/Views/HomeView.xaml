<UserControl x:Class="KighmuVpnWindows.UI.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgroundDarkBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== En-tête : statut de connexion ===== -->
        <StackPanel Grid.Row="0" Margin="0,16,0,0" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="DÉCONNECTÉ"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="StatusDetailText" Text="Appuyez pour vous connecter"
                       Style="{StaticResource KighmuSecondaryText}"
                       HorizontalAlignment="Center" Margin="0,4,0,0" />
        </StackPanel>

        <!-- ===== Bouton Connect circulaire avec logo superpose (identique Android) ===== -->
        <Grid Grid.Row="1" Width="160" Height="160"
              HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse Width="160" Height="160" Fill="{StaticResource AccentBlueBrush}" Opacity="0.07" />
            <Ellipse Width="138" Height="138" Fill="{StaticResource AccentBlueBrush}" Opacity="0.12" />
            <Button x:Name="ConnectButton"
                    Style="{StaticResource KighmuConnectButton}"
                    Click="ConnectButton_Click" />
            <Image Source="/Resources/logo.png" Width="76" Height="76"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- ===== Sélecteur de profil actif ===== -->
        <Border Grid.Row="2" Style="{StaticResource KighmuCard}" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="PROFIL ACTIF" Style="{StaticResource KighmuSectionHeader}" />
                <ComboBox x:Name="ProfileSelector" Style="{StaticResource KighmuComboBox}" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- ===== Stats de connexion (visible quand connecté) ===== -->
        <Border Grid.Row="3" Style="{StaticResource KighmuCard}" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="REÇU" Style="{StaticResource KighmuSectionHeader}" />
                    <TextBlock x:Name="DownloadText" Text="0 KB" Foreground="{StaticResource AccentGreenBrush}" FontWeight="Bold" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ENVOYÉ" Style="{StaticResource KighmuSectionHeader}" />
                    <TextBlock x:Name="UploadText" Text="0 KB" Foreground="{StaticResource AccentOrangeBrush}" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
