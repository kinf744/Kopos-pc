<UserControl x:Class="KighmuVpnWindows.UI.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Barre d'onglets (equivalent tab_container Android) ===== -->
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Padding="16,16,16,0">
            <StackPanel x:Name="TabBar" Orientation="Horizontal">
                <Button x:Name="TabSlowDns"  Content="SlowDNS"     Tag="0" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
                <Button x:Name="TabHttp"     Content="HTTP Proxy"  Tag="1" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
                <Button x:Name="TabSsl"      Content="SSH SSL"     Tag="2" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
                <Button x:Name="TabXray"     Content="V2Ray/Xray"  Tag="3" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
                <Button x:Name="TabV2Dns"    Content="V2Ray+DNS"   Tag="4" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
                <Button x:Name="TabHysteria" Content="Hysteria"    Tag="5" Click="Tab_Click" Padding="14,8" Margin="0,0,4,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- ===== Contenu : un panel squelette par mode (equivalent config_content Android) ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" x:Name="ConfigContent">

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelSlowDns" Visibility="Visible">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SLOWDNS PROFILES" Style="{StaticResource KighmuSectionHeader}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="BtnAddSlowDns" Content="+" Width="32" Height="32" FontSize="18"
                                    Style="{StaticResource KighmuButton}" Click="BtnAddSlowDns_Click" Padding="0" />
                        </Grid>
                        <TextBlock Text="Clic droit sur un profil pour le modifier, cloner ou supprimer"
                                   Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <StackPanel x:Name="SlowDnsProfilesList" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelHttp" Visibility="Collapsed">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HTTP PROXY PROFILES" Style="{StaticResource KighmuSectionHeader}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="BtnAddHttp" Content="+" Width="32" Height="32" FontSize="18"
                                    Style="{StaticResource KighmuButton}" Click="BtnAddHttp_Click" Padding="0" />
                        </Grid>
                        <TextBlock Text="Clic droit sur un profil pour le modifier, cloner ou supprimer"
                                   Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <StackPanel x:Name="HttpProfilesList" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelSsl" Visibility="Collapsed">
                        <TextBlock Text="SSH SSL/TLS" Style="{StaticResource KighmuSectionHeader}" Margin="0,0,0,12"/>

                        <!-- SSH Host -->
                        <TextBlock Text="Serveur SSH (Host)" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="SslHost" PlaceholderText="ex: vpn.example.com"
                                 Style="{StaticResource KighmuTextBox}" Margin="0,0,0,10"/>

                        <!-- SSH Port -->
                        <TextBlock Text="Port SSH" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="SslPort" PlaceholderText="443"
                                 Style="{StaticResource KighmuTextBox}" Margin="0,0,0,10"/>

                        <!-- SSH User -->
                        <TextBlock Text="Nom d'utilisateur SSH" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="SslUser" PlaceholderText="root"
                                 Style="{StaticResource KighmuTextBox}" Margin="0,0,0,10"/>

                        <!-- SSH Password -->
                        <TextBlock Text="Mot de passe SSH" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <PasswordBox x:Name="SslPass" Style="{StaticResource KighmuPasswordBox}" Margin="0,0,0,10"/>

                        <!-- SNI -->
                        <TextBlock Text="SNI (Server Name Indication)" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="SslSni" PlaceholderText="ex: cdn.cloudflare.com"
                                 Style="{StaticResource KighmuTextBox}" Margin="0,0,0,10"/>

                        <!-- TLS Version -->
                        <TextBlock Text="Version TLS" Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="SslTlsVersion" Style="{StaticResource KighmuComboBox}" Margin="0,0,0,10"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="TLS"/>
                            <ComboBoxItem Content="TLS 1.2"/>
                            <ComboBoxItem Content="TLS 1.3"/>
                        </ComboBox>

                        <!-- Allow Insecure -->
                        <CheckBox x:Name="SslAllowInsecure" Content="Autoriser certificat non sécurisé (Allow Insecure)"
                                  Foreground="{StaticResource TextPrimaryBrush}" IsChecked="True" Margin="0,0,0,12"/>

                        <!-- Bouton Enregistrer -->
                        <Button x:Name="BtnSslSave" Content="Enregistrer la configuration"
                                Style="{StaticResource KighmuButton}" HorizontalAlignment="Right"
                                Click="BtnSslSave_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelXray" Visibility="Collapsed">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="V2RAY / XRAY PROFILES" Style="{StaticResource KighmuSectionHeader}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="BtnAddXray" Content="+" Width="32" Height="32" FontSize="18"
                                    Style="{StaticResource KighmuButton}" Click="BtnAddXray_Click" Padding="0" />
                        </Grid>
                        <TextBlock Text="Clic droit sur un profil pour le modifier, cloner ou supprimer"
                                   Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <StackPanel x:Name="XrayProfilesList" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelV2Dns" Visibility="Collapsed">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="V2RAY+DNS PROFILES" Style="{StaticResource KighmuSectionHeader}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="BtnAddV2Dns" Content="+" Width="32" Height="32" FontSize="18"
                                    Style="{StaticResource KighmuButton}" Click="BtnAddV2Dns_Click" Padding="0" />
                        </Grid>
                        <TextBlock Text="Clic droit sur un profil pour le modifier, cloner ou supprimer"
                                   Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <StackPanel x:Name="V2DnsProfilesList" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KighmuCard}" Margin="0,0,0,12">
                    <StackPanel x:Name="PanelHysteria" Visibility="Collapsed">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HYSTERIA PROFILES" Style="{StaticResource KighmuSectionHeader}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="BtnAddHysteria" Content="+" Width="32" Height="32" FontSize="18"
                                    Style="{StaticResource KighmuButton}" Click="BtnAddHysteria_Click" Padding="0" />
                        </Grid>
                        <TextBlock Text="Clic droit sur un profil pour le modifier, cloner ou supprimer"
                                   Foreground="{StaticResource TextHintBrush}" FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap" />
                        <StackPanel x:Name="HysteriaProfilesList" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
