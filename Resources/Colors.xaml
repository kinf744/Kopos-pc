<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark theme background -->
    <Color x:Key="BackgroundDarkColor">#0D1117</Color>
    <Color x:Key="SurfaceDarkColor">#161B22</Color>
    <Color x:Key="SurfaceDarkElevatedColor">#1F2937</Color>
    <Color x:Key="SurfaceCardColor">#21262D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E6EDF3</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <Color x:Key="TextHintColor">#484F58</Color>

    <!-- Accent -->
    <Color x:Key="AccentBlueColor">#1F6FEB</Color>
    <Color x:Key="AccentBlueLightColor">#388BFD</Color>
    <Color x:Key="AccentGreenColor">#3FB950</Color>
    <Color x:Key="AccentPurpleColor">#8957E5</Color>
    <Color x:Key="AccentOrangeColor">#DB6D28</Color>

    <!-- Status -->
    <Color x:Key="SuccessGreenColor">#3FB950</Color>
    <Color x:Key="ErrorRedColor">#F85149</Color>
    <Color x:Key="WarningOrangeColor">#D29922</Color>
    <Color x:Key="InfoBlueColor">#388BFD</Color>

    <!-- Navigation -->
    <Color x:Key="NavActiveColor">#1F6FEB</Color>
    <Color x:Key="NavInactiveColor">#8B949E</Color>

    <!-- ===== Brushes ===== -->
    <SolidColorBrush x:Key="BackgroundDarkBrush" Color="{StaticResource BackgroundDarkColor}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDarkColor}"/>
    <SolidColorBrush x:Key="SurfaceDarkElevatedBrush" Color="{StaticResource SurfaceDarkElevatedColor}"/>
    <SolidColorBrush x:Key="SurfaceCardBrush" Color="{StaticResource SurfaceCardColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="{StaticResource TextHintColor}"/>

    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentBlueLightBrush" Color="{StaticResource AccentBlueLightColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}"/>

    <SolidColorBrush x:Key="SuccessGreenBrush" Color="{StaticResource SuccessGreenColor}"/>
    <SolidColorBrush x:Key="ErrorRedBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="WarningOrangeBrush" Color="{StaticResource WarningOrangeColor}"/>
    <SolidColorBrush x:Key="InfoBlueBrush" Color="{StaticResource InfoBlueColor}"/>

    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource ErrorRedColor}"/>
    <SolidColorBrush x:Key="NavActiveBrush" Color="{StaticResource NavActiveColor}"/>
    <SolidColorBrush x:Key="NavInactiveBrush" Color="{StaticResource NavInactiveColor}"/>

</ResourceDictionary>
